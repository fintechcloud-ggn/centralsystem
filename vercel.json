{
  "installCommand": "npm ci && npm --prefix Backend ci",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "functions": {
    "api/[...path].js": {
      "includeFiles": "Backend/**"
    },
    "api/admin/login.js": {
      "includeFiles": "Backend/**"
    },
    "api/admin/verify.js": {
      "includeFiles": "Backend/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
